---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Us • SwiftLink Logistics"
  description="Learn about SwiftLink Logistics, a trusted Michigan-based 3PL freight broker with 5,000+ carrier partners delivering nationwide across 48 states."
  keywords="about SwiftLink Logistics, 3PL company, freight broker Michigan, logistics provider, carrier network, transportation company, supply chain partner, freight brokerage firm"
  canonicalPath="/about"
  ogTitle="About SwiftLink Logistics | Michigan 3PL Freight Broker"
  ogDescription="Trusted Michigan-based 3PL freight broker with 5,000+ carrier partners delivering nationwide across 48 states."
>
  <!-- HERO -->
  <section class="relative bg-slate-900 py-28 text-center overflow-hidden">
    <div class="hero-video-container" aria-hidden="true">
      <video class="hero-video" autoplay muted loop playsinline preload="metadata">
        <source src="/videos/about.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <p class="text-orange-500 font-semibold text-sm tracking-widest uppercase mb-4 fade-in">About Us</p>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight leading-tight fade-in">About SwiftLink Logistics</h1>
      <p class="mt-6 text-xl text-slate-300 max-w-2xl mx-auto fade-in">Your trusted partner for freight transportation across the continental United States.</p>
    </div>
  </section>

  <!-- OUR STORY -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="text-orange-500 font-semibold text-sm tracking-widest uppercase mb-3">Our Story</p>
          <h2 class="text-4xl font-bold mb-6">Built on the Principle That Every Shipment Matters</h2>
          <p class="text-slate-300 leading-relaxed mb-5">SwiftLink Logistics, LLC is a third-party logistics (3PL) provider headquartered in Michigan. Founded on the principle that every shipment matters, we connect shippers with a vetted network of 5,000+ carrier partners across all 48 contiguous states.</p>
          <p class="text-slate-300 leading-relaxed mb-6">Our team combines deep industry expertise with technology-driven solutions to deliver reliable, transparent freight management. From a single pallet to a full truckload, we treat every load with the same level of care and urgency.</p>
          <img src="https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Freight trucks at a logistics hub" loading="lazy" class="rounded-2xl w-full h-56 object-cover border border-slate-800" />
        </div>
        <div class="fade-in bg-slate-900 rounded-3xl p-10 border border-slate-800">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center">
              <i class="fa-solid fa-bullseye text-orange-500 text-2xl" aria-hidden="true"></i>
            </div>
            <h3 class="text-2xl font-bold">Our Mission</h3>
          </div>
          <p class="text-slate-300 leading-relaxed">To simplify freight transportation by providing shippers with reliable capacity, real-time visibility, and dedicated support — at competitive rates. We believe logistics should be a competitive advantage, not a headache.</p>
          <div class="mt-8 flex items-center gap-3 text-orange-500 font-semibold text-sm">
            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
            <span>Trusted by 1,200+ businesses nationwide</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT SETS US APART -->
  <section class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <p class="text-orange-500 font-semibold text-sm tracking-widest uppercase mb-3">Our Advantages</p>
        <h2 class="text-4xl font-bold">What Sets Us Apart</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-shield-halved text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Vetted Carrier Network</h3>
          <p class="text-slate-400 leading-relaxed">5,000+ carriers, each safety-scored and fully insured. Every partner in our network meets rigorous safety and performance standards before moving a single load.</p>
        </div>
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-microchip text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Technology-Driven</h3>
          <p class="text-slate-400 leading-relaxed">Real-time tracking, digital BOLs, and automated reporting give you full visibility into every shipment from pickup to delivery.</p>
        </div>
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-user-tie text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Dedicated Account Managers</h3>
          <p class="text-slate-400 leading-relaxed">A single point of contact who knows your business inside and out. No call centers, no runaround — just a logistics expert who has your back.</p>
        </div>
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-map-location-dot text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Nationwide Coverage</h3>
          <p class="text-slate-400 leading-relaxed">Full coverage across all 48 contiguous states and every major lane. Whether it's coast-to-coast or a regional haul, we've got it covered.</p>
        </div>
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-tags text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Competitive Pricing</h3>
          <p class="text-slate-400 leading-relaxed">Leverage our freight volume and carrier relationships to access better rates. We negotiate aggressively so you don't have to.</p>
        </div>
        <div class="fade-in bg-slate-950 border border-slate-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa-solid fa-headset text-orange-500 text-xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">24/7 Support</h3>
          <p class="text-slate-400 leading-relaxed">Around-the-clock dispatch and customer service. Day or night, weekday or weekend, someone is always here to help with your shipment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGE BREAK -->
  <section class="py-0 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-4 fade-in">
        <img src="https://images.pexels.com/photos/2226458/pexels-photo-2226458.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Warehouse logistics operations" loading="lazy" class="rounded-2xl w-full h-52 object-cover border border-slate-800" />
        <img src="https://images.pexels.com/photos/1267338/pexels-photo-1267338.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Freight trucks on highway" loading="lazy" class="rounded-2xl w-full h-52 object-cover border border-slate-800" />
        <img src="https://images.pexels.com/photos/3862379/pexels-photo-3862379.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Team working in logistics office" loading="lazy" class="rounded-2xl w-full h-52 object-cover border border-slate-800" />
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <p class="text-orange-500 font-semibold text-sm tracking-widest uppercase mb-3">By the Numbers</p>
        <h2 class="text-4xl font-bold">Proven Performance at Scale</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="fade-in text-center bg-slate-900 border border-slate-800 rounded-2xl p-10">
          <p class="text-5xl font-extrabold text-orange-500 mb-2">48</p>
          <p class="text-slate-400 font-medium">States Covered</p>
        </div>
        <div class="fade-in text-center bg-slate-900 border border-slate-800 rounded-2xl p-10">
          <p class="text-5xl font-extrabold text-orange-500 mb-2">1,200+</p>
          <p class="text-slate-400 font-medium">Active Clients</p>
        </div>
        <div class="fade-in text-center bg-slate-900 border border-slate-800 rounded-2xl p-10">
          <p class="text-5xl font-extrabold text-orange-500 mb-2">99.8%</p>
          <p class="text-slate-400 font-medium">On-Time Delivery</p>
        </div>
        <div class="fade-in text-center bg-slate-900 border border-slate-800 rounded-2xl p-10">
          <p class="text-5xl font-extrabold text-orange-500 mb-2">5,000+</p>
          <p class="text-slate-400 font-medium">Carrier Partners</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR VALUES -->
  <section class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <p class="text-orange-500 font-semibold text-sm tracking-widest uppercase mb-3">What We Stand For</p>
        <h2 class="text-4xl font-bold">Our Values</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="fade-in text-center p-8">
          <div class="w-16 h-16 bg-orange-500/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <i class="fa-solid fa-handshake text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Reliability</h3>
          <p class="text-slate-400">We do what we say, every time. Your freight arrives on time, in full, without excuses.</p>
        </div>
        <div class="fade-in text-center p-8">
          <div class="w-16 h-16 bg-orange-500/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <i class="fa-solid fa-eye text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Transparency</h3>
          <p class="text-slate-400">No hidden fees, no surprises. Clear communication and real-time visibility on every load.</p>
        </div>
        <div class="fade-in text-center p-8">
          <div class="w-16 h-16 bg-orange-500/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <i class="fa-solid fa-people-group text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Partnership</h3>
          <p class="text-slate-400">We're an extension of your team. Your success is our success, and we invest in long-term relationships.</p>
        </div>
        <div class="fade-in text-center p-8">
          <div class="w-16 h-16 bg-orange-500/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <i class="fa-solid fa-hard-hat text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Safety</h3>
          <p class="text-slate-400">Safety is non-negotiable. Every carrier is vetted, every load is insured, every mile is monitored.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-3xl mx-auto px-6 text-center fade-in">
      <h2 class="text-4xl font-bold mb-6">Ready to Ship?</h2>
      <p class="text-xl text-slate-300 mb-10">Experience the SwiftLink difference. Get a free, no-obligation quote in minutes and see why 1,200+ businesses trust us with their freight.</p>
      <a href="/quote" class="inline-flex items-center gap-3 bg-orange-500 hover:bg-orange-600 px-10 py-4 rounded-2xl font-semibold text-lg transition">
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i> Get Your Free Quote
      </a>
    </div>
  </section>
</BaseLayout>
