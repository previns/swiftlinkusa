---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroService from "../components/HeroService.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Full Truckload (FTL) Shipping",
  provider: {
    "@type": "LocalBusiness",
    name: "SwiftLink Logistics, LLC",
    url: "https://www.swiftlinkusa.com",
    telephone: "+1-248-987-6776",
  },
  areaServed: { "@type": "Country", name: "United States" },
  description:
    "Dedicated 53-foot trailers for high-volume freight. Dry van, flatbed, reefer, and specialty equipment with direct point-to-point delivery nationwide.",
  url: "https://www.swiftlinkusa.com/ftl/",
};
---

<BaseLayout
  title="Full Truckload (FTL) Shipping • SwiftLink Logistics"
  description="Full truckload shipping with SwiftLink Logistics. Dedicated dry van, flatbed, reefer, and specialty trailers with direct delivery across 48 states."
  keywords="full truckload shipping, FTL freight, dedicated trailer, dry van shipping, flatbed freight, reefer transport, truckload carrier, FTL logistics, nationwide trucking"
  canonicalPath="/ftl"
  ogTitle="Full Truckload (FTL) Shipping | SwiftLink Logistics"
  ogDescription="Dedicated FTL shipping with dry van, flatbed, reefer, and specialty trailers. Direct delivery across 48 states."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <HeroService
    videoSrc="/videos/ftl.mp4"
    pillIcon="fa-truck"
    pillText="Dedicated Capacity Nationwide"
    titleStart="Full Truckload"
    titleAccent="(FTL)"
    titleEnd="Shipping"
    subtitle="Dedicated trailers, direct routes, and zero freight handling between pickup and delivery. The fastest, most secure way to move large shipments across the country."
    primaryCta={{ href: "/quote/?service=FTL", text: "Get an FTL Quote" }}
    secondaryCta={{ href: "#what-is-ftl", text: "Learn More" }}
  />

  <!-- WHAT IS FTL -->
  <section id="what-is-ftl" class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <h2 class="text-4xl font-bold mb-6">What is FTL Shipping?</h2>
          <p class="text-slate-300 text-lg leading-relaxed mb-6">Full Truckload (FTL) shipping means your freight gets an entire trailer dedicated exclusively to your shipment. Unlike LTL, your cargo is the only freight on the truck — it moves directly from origin to destination with no stops, no transfers, and no rehandling at terminals.</p>
          <p class="text-slate-300 text-lg leading-relaxed mb-6">FTL is the ideal solution when your shipment is large enough to fill a significant portion of a trailer, typically <strong class="text-white">10,000 lbs or more</strong>, or <strong class="text-white">10+ pallets</strong>. Even if your freight doesn't fill the entire trailer, FTL can still be more cost-effective and faster than LTL for shipments approaching these thresholds.</p>
          <p class="text-slate-300 text-lg leading-relaxed">With SwiftLink's FTL service, you get a dedicated driver, a guaranteed pickup window, and point-to-point delivery with real-time GPS tracking from dispatch to final delivery.</p>
        </div>
        <div class="fade-in">
          <div class="bg-slate-900 rounded-3xl p-8 border border-slate-800">
            <h3 class="text-xl font-bold mb-6 text-orange-500">When to Choose FTL</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300">Shipments weighing <strong class="text-white">10,000 – 45,000 lbs</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300">Freight filling <strong class="text-white">10 or more standard pallets</strong> (48"x40")</span>
              </li>
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300">High-value or fragile goods requiring <strong class="text-white">minimal handling</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300"><strong class="text-white">Time-sensitive deliveries</strong> that can't afford terminal delays</span>
              </li>
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300">Temperature-controlled, hazmat, or <strong class="text-white">specialty freight</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-check-circle text-orange-500 mt-1" aria-hidden="true"></i>
                <span class="text-slate-300">Consistent, high-volume shipping lanes requiring <strong class="text-white">dedicated capacity</strong></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRAILER TYPES -->
  <section class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <h2 class="text-4xl font-bold mb-4">FTL Trailer Types We Offer</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">From standard dry vans to specialty flatbeds and temperature-controlled reefers, we match the right equipment to your freight requirements.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Dry Van -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-warehouse text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Dry Van</h3>
          <p class="text-slate-400 mb-4">The most common trailer type in North America. Fully enclosed with rigid walls, roof, and floor to protect freight from the elements.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-ruler text-orange-500 text-xs" aria-hidden="true"></i> Interior: 53' L x 8'6" W x 9' H</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-weight-hanging text-orange-500 text-xs" aria-hidden="true"></i> Max payload: 45,000 lbs</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-cubes text-orange-500 text-xs" aria-hidden="true"></i> Capacity: 26 standard pallets</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-box text-orange-500 text-xs" aria-hidden="true"></i> ~2,390 cubic feet of space</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: General merchandise, consumer goods, packaged food, electronics, retail inventory</p>
        </div>
        <!-- Flatbed -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-trailer text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Flatbed</h3>
          <p class="text-slate-400 mb-4">Open-deck trailer with no sides, roof, or enclosure. Allows top, side, and rear loading with cranes, forklifts, or other heavy equipment.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-ruler text-orange-500 text-xs" aria-hidden="true"></i> Deck: 48' L x 8'6" W, 60" height</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-weight-hanging text-orange-500 text-xs" aria-hidden="true"></i> Max payload: 48,000 lbs</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-arrows-up-down text-orange-500 text-xs" aria-hidden="true"></i> Max freight height: 8'6"</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-link text-orange-500 text-xs" aria-hidden="true"></i> Securement: chains, straps, tarps</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: Steel coils, lumber, machinery, construction materials, oversized equipment</p>
        </div>
        <!-- Reefer -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-temperature-low text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Reefer / Refrigerated</h3>
          <p class="text-slate-400 mb-4">Temperature-controlled trailers equipped with built-in refrigeration units. Maintains precise temperatures from -20&deg;F to 70&deg;F throughout transit.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-ruler text-orange-500 text-xs" aria-hidden="true"></i> Interior: 53' L x 8'2" W x 8'6" H</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-weight-hanging text-orange-500 text-xs" aria-hidden="true"></i> Max payload: 40,000 – 44,000 lbs</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-thermometer-half text-orange-500 text-xs" aria-hidden="true"></i> Temp range: -20&deg;F to 70&deg;F</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-cubes text-orange-500 text-xs" aria-hidden="true"></i> Capacity: 22–24 pallets</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: Produce, frozen foods, dairy, pharmaceuticals, chemicals, floral</p>
        </div>
        <!-- Step Deck -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-stairs text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Step Deck (Drop Deck)</h3>
          <p class="text-slate-400 mb-4">A two-level flatbed with an upper deck and a lower deck, providing additional vertical clearance for taller freight that won't fit on a standard flatbed.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-ruler text-orange-500 text-xs" aria-hidden="true"></i> Upper: 11' L / Lower: 37' L</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-weight-hanging text-orange-500 text-xs" aria-hidden="true"></i> Max payload: 43,000 – 48,000 lbs</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-arrows-up-down text-orange-500 text-xs" aria-hidden="true"></i> Max freight height: 10' (lower deck)</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-truck-ramp-box text-orange-500 text-xs" aria-hidden="true"></i> No ramp needed for lower deck</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: Tall machinery, agricultural equipment, industrial components, vehicles</p>
        </div>
        <!-- Conestoga -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-tarp text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Conestoga</h3>
          <p class="text-slate-400 mb-4">A flatbed trailer with a retractable tarpaulin system that slides open for side or top loading, then closes to provide full weather protection like a dry van.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-ruler text-orange-500 text-xs" aria-hidden="true"></i> Deck: 48' L x 8'6" W</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-weight-hanging text-orange-500 text-xs" aria-hidden="true"></i> Max payload: 44,000 – 46,000 lbs</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-shield text-orange-500 text-xs" aria-hidden="true"></i> Full weather protection</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-arrows-left-right text-orange-500 text-xs" aria-hidden="true"></i> Side-loading capable</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: Building materials, metal products, freight requiring weather protection + crane loading</p>
        </div>
        <!-- Power Only -->
        <div class="fade-in bg-slate-950 rounded-2xl p-8 border border-slate-800 hover:border-orange-500/50 transition-all duration-300">
          <div class="w-14 h-14 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-truck-moving text-orange-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-bold mb-3">Power Only</h3>
          <p class="text-slate-400 mb-4">We provide the tractor and driver while you supply the trailer. Perfect for shippers with their own trailer pool who need reliable drivers and capacity on demand.</p>
          <ul class="space-y-2 text-sm text-slate-400">
            <li class="flex items-center gap-2"><i class="fa-solid fa-truck-front text-orange-500 text-xs" aria-hidden="true"></i> Tractor + driver supplied by SwiftLink</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-trailer text-orange-500 text-xs" aria-hidden="true"></i> Your trailer, our horsepower</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-clock text-orange-500 text-xs" aria-hidden="true"></i> Flexible scheduling</li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-dollar-sign text-orange-500 text-xs" aria-hidden="true"></i> Reduced equipment costs</li>
          </ul>
          <p class="text-xs text-slate-500 mt-4">Ideal for: Companies with trailer pools, drop-and-hook operations, seasonal overflow</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <h2 class="text-4xl font-bold mb-4">Benefits of FTL Shipping</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">Full truckload shipping delivers measurable advantages in speed, security, and cost-efficiency for large-volume shippers.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-bolt text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Faster Transit Times</h3>
            <p class="text-slate-400 text-sm">Direct point-to-point delivery with no terminal stops, no freight consolidation, and no hub transfers. Your shipment moves straight from origin to destination.</p>
          </div>
        </div>
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-shield-halved text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Reduced Damage Risk</h3>
            <p class="text-slate-400 text-sm">Your freight is loaded once and unloaded once. With no cross-docking, rehandling, or pallet reorganization, the risk of damage or loss drops significantly.</p>
          </div>
        </div>
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-dollar-sign text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Cost-Effective at Scale</h3>
            <p class="text-slate-400 text-sm">FTL pricing is based on a flat per-mile rate rather than per-pallet or per-hundredweight. For shipments over 10,000 lbs, FTL often costs less than equivalent LTL rates.</p>
          </div>
        </div>
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-lock text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Dedicated Capacity</h3>
            <p class="text-slate-400 text-sm">The entire trailer is reserved exclusively for your freight. No sharing space, no competing for capacity, and no risk of bumped shipments during peak season.</p>
          </div>
        </div>
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-calendar-check text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Flexible Scheduling</h3>
            <p class="text-slate-400 text-sm">Choose your pickup date and time. Need an early morning, evening, or weekend pickup? FTL gives you full control over your shipping schedule and delivery appointments.</p>
          </div>
        </div>
        <div class="fade-in flex items-start gap-4">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-satellite-dish text-orange-500 text-lg" aria-hidden="true"></i>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Real-Time Visibility</h3>
            <p class="text-slate-400 text-sm">GPS tracking on every load with automated check-calls, milestone updates, and ETA notifications. Know exactly where your freight is at every moment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 fade-in">
        <h2 class="text-4xl font-bold mb-4">Industries We Serve</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">SwiftLink moves full truckload freight for companies across the most demanding industry verticals in the United States.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-6">
        <div class="fade-in bg-slate-950 rounded-2xl p-6 border border-slate-800 text-center hover:border-orange-500/50 transition">
          <i class="fa-solid fa-industry text-orange-500 text-3xl mb-4" aria-hidden="true"></i>
          <h3 class="font-bold mb-2">Manufacturing</h3>
          <p class="text-slate-400 text-sm">Raw materials inbound, finished goods outbound. JIT delivery to production lines and distribution centers.</p>
        </div>
        <div class="fade-in bg-slate-950 rounded-2xl p-6 border border-slate-800 text-center hover:border-orange-500/50 transition">
          <i class="fa-solid fa-cart-shopping text-orange-500 text-3xl mb-4" aria-hidden="true"></i>
          <h3 class="font-bold mb-2">Retail &amp; E-Commerce</h3>
          <p class="text-slate-400 text-sm">Fulfillment center replenishment, seasonal inventory surges, and store-to-DC transfers at scale.</p>
        </div>
        <div class="fade-in bg-slate-950 rounded-2xl p-6 border border-slate-800 text-center hover:border-orange-500/50 transition">
          <i class="fa-solid fa-car text-orange-500 text-3xl mb-4" aria-hidden="true"></i>
          <h3 class="font-bold mb-2">Automotive</h3>
          <p class="text-slate-400 text-sm">OEM parts, assemblies, and aftermarket components with strict delivery windows and sequence requirements.</p>
        </div>
        <div class="fade-in bg-slate-950 rounded-2xl p-6 border border-slate-800 text-center hover:border-orange-500/50 transition">
          <i class="fa-solid fa-utensils text-orange-500 text-3xl mb-4" aria-hidden="true"></i>
          <h3 class="font-bold mb-2">Food &amp; Beverage</h3>
          <p class="text-slate-400 text-sm">Reefer and dry van for perishables, frozen goods, and ambient-temp beverages. FSMA-compliant carriers.</p>
        </div>
        <div class="fade-in bg-slate-950 rounded-2xl p-6 border border-slate-800 text-center hover:border-orange-500/50 transition">
          <i class="fa-solid fa-helmet-safety text-orange-500 text-3xl mb-4" aria-hidden="true"></i>
          <h3 class="font-bold mb-2">Construction</h3>
          <p class="text-slate-400 text-sm">Flatbed and step deck for steel, lumber, heavy equipment, and building materials to job sites nationwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-4xl mx-auto px-6 text-center fade-in">
      <div class="bg-gradient-to-br from-slate-900 to-slate-900/50 rounded-3xl p-12 border border-slate-800">
        <i class="fa-solid fa-truck text-orange-500 text-5xl mb-6" aria-hidden="true"></i>
        <h2 class="text-4xl font-bold mb-4">Ready to Ship Full Truckload?</h2>
        <p class="text-slate-300 text-lg mb-8 max-w-xl mx-auto">Tell us your origin, destination, and freight details. Our FTL specialists will provide a competitive rate within minutes — not hours.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/quote/?service=FTL" class="bg-orange-500 hover:bg-orange-600 px-10 py-4 rounded-2xl font-semibold text-lg transition">Get Your FTL Quote</a>
          <a href="/contact" class="border border-slate-600 hover:border-orange-500 px-10 py-4 rounded-2xl font-semibold text-lg transition">Talk to a Specialist</a>
        </div>
        <p class="text-sm text-slate-500 mt-6">Average response time: under 15 minutes during business hours</p>
      </div>
    </div>
  </section>
</BaseLayout>
