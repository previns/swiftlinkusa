---
// Home page — composes the cycling hero, trust bar, stats, services grid, and "why us" row.
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCycling from "../components/HeroCycling.astro";
import TrustBar from "../components/TrustBar.astro";
import StatsSection from "../components/StatsSection.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import WhyUs from "../components/WhyUs.astro";
import JsonLdLocalBusiness from "../components/JsonLdLocalBusiness.astro";

const heroVideos = [
  { src: "/videos/home-1.mp4", label: "Drayage operations" },
  { src: "/videos/home-2.mp4", label: "Full truckload on the highway" },
  { src: "/videos/home-3.mp4", label: "Less-than-truckload warehouse" },
];
---

<BaseLayout
  title="SwiftLink USA | 3PL Freight Brokerage | Ship with Confidence"
  description="SwiftLink Logistics is a Michigan-based 3PL freight broker offering FTL, LTL, drayage, expedited, heavy haul, and hazmat shipping across 48 states."
  keywords="3PL, freight broker, logistics company, FTL shipping, LTL shipping, drayage, expedited freight, heavy haul, hazmat transport, Michigan logistics"
  canonicalPath="/"
  ogTitle="SwiftLink Logistics — 3PL Freight Brokerage | Ship with Confidence"
>
  <HeroCycling videos={heroVideos} />
  <TrustBar />
  <StatsSection />
  <ServicesGrid />
  <WhyUs />
  <JsonLdLocalBusiness slot="head" />
</BaseLayout>
